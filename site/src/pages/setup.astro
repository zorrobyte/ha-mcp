    "clientNote": "Requires a Claude Pro, Max, Team, or Enterprise subscription. Use the 'Search and tools' button in the chat composer to enable/disable individual tools per conversation.",
  },
  {
    "id": "gemini-cli",
    "name": "Gemini CLI",
    "company": "Google",
