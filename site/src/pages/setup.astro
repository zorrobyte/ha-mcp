    "accuracy": 4,
    "order": 12,
    "httpNote": "stdio only - use mcp-remote for HTTP servers",
    "clientNote": "Requires IDE 2025.1+ with the AI Assistant plugin (251.26094.80.5+). Restart IDE after config changes. Migrating from Claude Desktop? The MCP Servers panel has an 'Import from Claude' button to auto-import existing servers.",
  },
  {
    "id": "zed",
    "name": "Zed",
    "company": "Zed Industries",
    "logo": "/logos/zed.svg",
    "transports": ["stdio"],
    "configFormat": "json",
    "configLocation": "macOS/Linux: ~/.config/zed/settings.json\nWindows: %APPDATA%\\Zed\\settings.json\nProject-specific: .zed/settings.json (overrides global)",
    "accuracy": 4,
    "order": 13,
    "httpNote": "stdio only - limited HTTP support",
    "clientNote": "Settings file supports JSON with // comments.",
  },
  {
    "id": "continue",
    "name": "Continue",
    "company": "Continue.dev",
    "logo": "/logos/continue.svg",
    "transports": ["stdio", "sse", "streamable-http"],
    "configFormat": "yaml",
    "configLocation": ".continue/mcpServers/",
    "accuracy": 4,
    "order": 14,
    "clientNote": "MCP servers are only available in Continue's Agent Mode — switch to Agent Mode using the agent selector near the chat input.",
  },
  {
    "id": "raycast",
    "name": "Raycast",
    "company": "Raycast",
    "logo": "/logos/raycast.svg",
    "transports": ["stdio", "sse", "streamable-http"],
    "configFormat": "json",
    "configLocation": "Manage MCP Servers → Show Config File in Finder",
    "accuracy": 4,
    "order": 15,
    "httpNote": "HTTP transport is experimental (requires v1.100.0+)",
    "clientNote": "Requires Raycast v1.98.0+ for MCP, v1.100.0+ for HTTP transport. Pro subscription or BYOK required.",
  },
  {
    "id": "codex",
    "name": "Codex",
    "company": "OpenAI",
